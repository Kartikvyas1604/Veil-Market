# VEIL Environment Variables
# Copy this to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WalletConnect (for wallet connection)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Domain
NEXT_PUBLIC_DOMAIN=localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Avalanche RPC
NEXT_PUBLIC_AVALANCHE_RPC=https://api.avax-test.network/ext/bc/C/rpc

# Contract Addresses (after deployment)
NEXT_PUBLIC_VEIL_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REGISTRAR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_THRESHOLD_DECRYPTION_ADDRESS=0x0000000000000000000000000000000000000000

# eERC Circuit Files (for Groth16 proof generation)
NEXT_PUBLIC_EERC_WASM_PATH=/circuits/transfer.wasm
NEXT_PUBLIC_EERC_ZKEY_PATH=/circuits/transfer.zkey
